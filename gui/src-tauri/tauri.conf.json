{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Croc",
  "version": "0.1.3",
  "identifier": "app.croc.gui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Croc",
        "width": 720,
        "height": 640,
        "minWidth": 560,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "deb", "appimage"],
    "copyright": "Copyright © Suhaas (interfluve-wav). Powered by schollz/croc.",
    "shortDescription": "Secure encrypted file transfer with croc",
    "longDescription": "Desktop GUI for croc — cross-platform encrypted peer-to-peer file transfer with drag-and-drop, QR codes, and LAN mode. No cloud upload required.",
    "resources": ["bin/"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
